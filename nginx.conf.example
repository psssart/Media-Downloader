# HTTP → HTTPS
server {
    listen 80;
    server_name media-downloader.null-land.com;
    return 301 https://$host$request_uri;
}

# HTTPS → Docker
server {
    listen 443 ssl http2;
    server_name media-downloader.null-land.com;

    ssl_certificate     /etc/letsencrypt/live/null-land.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/null-land.com/privkey.pem;
    include             /etc/nginx/snippets/ssl-params.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 50m;

    # Protect the .well-known challenge path too
    location ^~ /.well-known/acme-challenge/ {
        root /var/www/letsencrypt;
        allow all;
    }

    location / {
        proxy_pass         http://127.0.0.1:8082;
        proxy_http_version 1.1;

        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   X-Forwarded-Host  $host;
        proxy_set_header   X-Forwarded-Port  $server_port;
        proxy_read_timeout 90;
    }
}